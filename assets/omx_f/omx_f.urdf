  <!--
    socket_hardware_interface: one SocketSystemInterface talking to the vendored
    DYNAMIXEL driver process over $(arg socket_path). Each joint addresses its
    motor by device_id. profile_velocity/acceleration (deg/s, deg/s^2 — set via
    the $(arg profile_velocity)/$(arg profile_acceleration) whole-arm speed cap
    above) shape every trajectory the firmware executes, so no single position
    command — from teleop, the debug tool, or a stray topic pub — can move the
    arm faster than this, no matter how big the commanded jump is.
    position_p/d_gain are raw DYNAMIXEL register values. min/max_position_limit
    are raw ticks (firmware safety clamp, single-turn Position Control Mode only).
    Values otherwise follow the ROBOTIS omx_f.ros2_control.xacro.
  -->
  <ros2_control name="omx_f_system" type="system">
    <hardware>
      <plugin>socket_hardware_interface/SocketSystemInterface</plugin>
      <param name="socket_path">/tmp/omx.sock</param>
    </hardware>
    <joint name="joint1">
      <param name="device_id">11</param>
      <param name="operating_mode">extended_position</param>
      <param name="drive_mode">4</param>
      <param name="profile_velocity">50</param>
      <param name="profile_acceleration">25</param>
      <param name="position_p_gain">1000</param>
      <param name="position_i_gain">0</param>
      <param name="position_d_gain">1000</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="temperature"/>
      <state_interface name="error"/>
      <state_interface name="pwm"/>
      <state_interface name="voltage"/>
      <state_interface name="moving"/>
      <state_interface name="homing_offset"/>
    </joint>
    <!-- min/max_position_limit are DYNAMIXEL EEPROM registers in raw ticks, and
         only make sense against a known homing calibration. ROBOTIS' official
         values (830/3129, 1024/3140) assume their factory zero, which this
         driver doesn't replicate, so a resting pose can fall outside them and
         the firmware rejects the hold-position goal on activation. Set to the
         full single-turn range (0/4095) = no soft clamp; this also overwrites
         any stale limit a previous CONFIGURE wrote to EEPROM. Re-introduce real
         limits once the arm's zero is calibrated (see SET_ZERO / homing_offset). -->
    <joint name="joint2">
      <param name="device_id">12</param>
      <param name="operating_mode">position</param>
      <param name="drive_mode">4</param>
      <param name="profile_velocity">50</param>
      <param name="profile_acceleration">25</param>
      <param name="position_p_gain">1000</param>
      <param name="position_i_gain">0</param>
      <param name="position_d_gain">1000</param>
      <param name="min_position_limit">0</param>
      <param name="max_position_limit">4095</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="temperature"/>
      <state_interface name="error"/>
      <state_interface name="pwm"/>
      <state_interface name="voltage"/>
      <state_interface name="moving"/>
      <state_interface name="homing_offset"/>
    </joint>
    <joint name="joint3">
      <param name="device_id">13</param>
      <param name="operating_mode">position</param>
      <param name="drive_mode">4</param>
      <param name="profile_velocity">50</param>
      <param name="profile_acceleration">25</param>
      <param name="position_p_gain">1000</param>
      <param name="position_i_gain">0</param>
      <param name="position_d_gain">1000</param>
      <param name="min_position_limit">0</param>
      <param name="max_position_limit">4095</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="temperature"/>
      <state_interface name="error"/>
      <state_interface name="pwm"/>
