    <joint name="gripper_joint_1">
      <param name="device_id">16</param>
      <param name="operating_mode">current_based_position</param>
      <param name="drive_mode">4</param>
      <param name="profile_velocity">50</param>
      <param name="profile_acceleration">25</param>
      <param name="current_limit">600</param>
      <param name="goal_current">600</param>
      <param name="shutdown">21</param>
      <param name="position_p_gain">1000</param>
      <param name="position_i_gain">0</param>
      <param name="position_d_gain">1000</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="temperature"/>
      <state_interface name="error"/>
      <state_interface name="pwm"/>
      <state_interface name="voltage"/>
      <state_interface name="moving"/>
      <state_interface name="homing_offset"/>
    </joint>
  </ros2_control>
