# Shared by the sim<->real bridge compose. ROS_DOMAIN_ID must match BOTH the real
# arm (omx_arm_image defaults to 1) and Isaac Sim (launch it with the same value).
ROS_DOMAIN_ID=1

# Which robot profile to run (file profile/<PROFILE>.profile.yaml).
#   omx_l = twin the LEADER (hand-drag it, read-only)  <- easiest M1 demo
#   omx_f = twin the FOLLOWER (framework target)
PROFILE=omx_f
